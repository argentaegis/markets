# Observer — configuration
OBSERVER_PROVIDER=sim
OBSERVER_LOG_LEVEL=INFO
BACKEND_PORT=8000
FRONTEND_PORT=5173

# State persistence (optional — unset = disabled)
# OBSERVER_DB_PATH=observer.db

# Schwab provider credentials (required when OBSERVER_PROVIDER=schwab)
# SCHWAB_API_KEY=your_api_key
# SCHWAB_APP_SECRET=your_app_secret
# SCHWAB_CALLBACK_URL=https://127.0.0.1
# SCHWAB_TOKEN_PATH=./schwab_token.json
# SCHWAB_ACCOUNT_ID=1234567890
